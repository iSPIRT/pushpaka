{
  "name": "Pushpaka QGC Plugin (Qt 6)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder}/..,target=/workspace,type=bind",
  "postCreateCommand": "bash /workspace/qgc-plugin/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "ms-vscode.cpptools-extension-pack"
      ],
      "settings": {
        "cmake.buildDirectory": "/workspace/qgc-plugin/build",
        "cmake.sourceDirectory": "/workspace/qgc-plugin/qgroundcontrol",
        "cmake.configureArgs": [
          "-DCMAKE_BUILD_TYPE=Debug"
        ]
      }
    }
  }
}
