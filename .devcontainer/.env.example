# Pushpaka devcontainer environment
# Copy to .env and adjust ports if any conflict with existing services on your machine.

# ── Service credentials ───────────────────────────────────────────────────────
POSTGRES_PASSWORD=secret
POSTGRES_USER=postgres
SPICEDB_GRPC_PRESHARED_KEY=somerandomkeyhere

# ── Java service config ────────────────────────────────────────────────────────
# Used by SpicedbClient; must match host:port exposed by docker-compose spicedb service
SPICEDB_TARGET=localhost:50051
# Keycloak base URL used by Spring OAuth2 resource server config
KEYCLOAK_URL=http://localhost:18080

# ── Host port mappings ────────────────────────────────────────────────────────
# Change these if you have port conflicts (e.g. another Postgres on 5432)
PORT_POSTGRES=15432
PORT_KEYCLOAK=18080
PORT_SPICEDB_HTTP=18081
PORT_SPICEDB_GRPC=19090
PORT_SPICEDB_GRPC_ALT=50051
PORT_REGISTRY=8082
PORT_FLIGHT_AUTH=8083
PORT_SITL_TCP=5760
PORT_SITL_UDP=14550
